NEXT_PUBLIC_API_URL=http://localhost:4000
# Rodapé: horário do último build (ex.: 18/02/2025 14:30). Defina no build/deploy para mostrar no site.
# NEXT_PUBLIC_LAST_UPDATED=18/02/2025 14:30

# Login para acessar o site (opcional). Se LOGIN_USER e LOGIN_PASSWORD não forem definidos, o site fica aberto.
# LOGIN_USER=admin
# LOGIN_PASSWORD=sua_senha_segura
# SESSION_SECRET=uma_string_aleatoria_longa_para_assinatura_do_cookie

# Link curto: base URL para /r/CODE. O backend tenta, em ordem: SHORT_LINK_BASE_URL, API_URL, NEXT_PUBLIC_APP_URL.
# Ex.: SHORT_LINK_BASE_URL=https://mb-ofertas.vercel.app (app) ou https://api.xxx.com (backend).
# Defina pelo menos um no backend para que posts e mensagens usem link curto em vez do link longo.
# SHORT_LINK_BASE_URL=https://mb-ofertas.vercel.app
