NEXT_PUBLIC_API_URL=http://localhost:4000
# O rodapé exibe o horário atual em UTC-3 (Brasília) automaticamente; não é necessário configurar.

# Login para acessar o site (opcional). Se LOGIN_USER e LOGIN_PASSWORD não forem definidos, o site fica aberto.
# LOGIN_USER=admin
# LOGIN_PASSWORD=sua_senha_segura
# SESSION_SECRET=uma_string_aleatoria_longa_para_assinatura_do_cookie

# Link curto: base URL onde /r/CODE é servido. Use a URL do app Next.js (ex: https://mb-ofertas.vercel.app) ou do backend (ex: https://api.xxx.com).
# Se não definir, as mensagens usarão o link longo (afiliado) sem encurtar.
# SHORT_LINK_BASE_URL=https://mb-ofertas.vercel.app
