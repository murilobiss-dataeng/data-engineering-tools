# URL do feed de produtos aprovados (path /api/products/feed na sua API).
API_URL=https://meusite.com/api/products/feed

# Opcional: filtra só ofertas dessa categoria (mesmos slugs do painel: health, tech, ofertas, faith).
# No GitHub Actions cada job define CHANNEL_SLUG e o CHAT_ID do canal correspondente.
# CHANNEL_SLUG=health

# Destino: ID do canal (ex.: 120363405814099508@newsletter) ou do grupo (XXX@g.us).
CHAT_ID=120363405814099508@newsletter

# Intervalo em minutos entre cada verificação da API
CRON_INTERVAL_MINUTES=10

# Pausa em minutos entre cada post enviado (evita flood no canal). Padrão: 10.
# DELAY_BETWEEN_POSTS_MINUTES=10

# Pasta onde salvar sessão (LocalAuth) e dados (evitar duplicados)
DATA_PATH=./data

# Opcional: clientId para a sessão (apenas letras, números, _ e -). Troque de valor para
# começar sessão limpa (ex.: ao mudar de WhatsApp normal para WhatsApp Business no mesmo data/).
# AUTH_CLIENT_ID=channel_bot

# Por padrão true: não envia posts sem imagem (só envia quando tiver imageUrl). Para enviar também posts só texto, use SKIP_POSTS_WITHOUT_IMAGE=false
# SKIP_POSTS_WITHOUT_IMAGE=true
